<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="AetherisOne.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#07111F">

    <Grid>

        <Image
            Source="aetherishero.png"
            Aspect="AspectFill" />

        <BoxView
            Color="#07111F"
            Opacity="0.35" />

        <ScrollView>
            <VerticalStackLayout
                Padding="24"
                Spacing="20">

                <Image
                    Source="aetheris_ai_minimal_logo.svg"
                    HeightRequest="75"
                    HorizontalOptions="Center" />

                <Label
                    Text="AETHERIS ONE"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalTextAlignment="Center" />

                <Border
                    x:Name="DailyQuoteCard"
                    BackgroundColor="#10233A"
                    Stroke="#2F7EDB"
                    StrokeThickness="1"
                    Padding="20">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDailyQuoteTapped" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="💡" FontSize="30" HorizontalTextAlignment="Center" />

                        <Label
                            Text="Quote of the Day"
                            FontAttributes="Bold"
                            TextColor="#9DB7D5"
                            HorizontalTextAlignment="Center" />

                        <Label
                            x:Name="DailyQuoteLabel"
                            Text="Loading..."
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="White"
                            HorizontalTextAlignment="Center" />

                        <Label
                            x:Name="DailyAuthorLabel"
                            Text="Loading..."
                            TextColor="#9DB7D5"
                            HorizontalTextAlignment="Center" />

                        <Label
                            Text="Tap to explore reflections"
                            TextColor="#D6E4F0"
                            FontSize="13"
                            HorizontalTextAlignment="Center"
                            Opacity="0.8" />
                    </VerticalStackLayout>

                </Border>

                <Border BackgroundColor="#10233A" Stroke="#2F7EDB" StrokeThickness="1" Padding="18">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="✅" FontSize="30" HorizontalTextAlignment="Center" />
                        <Label Text="Task Manager" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#10233A" Stroke="#2F7EDB" StrokeThickness="1" Padding="18">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="📅" FontSize="30" HorizontalTextAlignment="Center" />
                        <Label Text="Calendar" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#10233A" Stroke="#2F7EDB" StrokeThickness="1" Padding="18">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="📓" FontSize="30" HorizontalTextAlignment="Center" />
                        <Label Text="Notebook" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>